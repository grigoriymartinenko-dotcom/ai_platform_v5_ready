# services/agent_service/tools/weather.py

import httpx
import urllib.parse
from services.utils.logger import get_logger, TraceAdapter

base_logger = get_logger("Weather")
logger = TraceAdapter(base_logger, {})
API_KEY = "07108cf067a5fdf5aa26dce75354400f"

logger.debug(f"WEATHER start")
async def get_weather(city: str):
    if not city:
        return "Город не указан."

    city_param = urllib.parse.quote(city)
    url = f"http://api.openweathermap.org/data/2.5/weather?q={city_param}&appid={API_KEY}&units=metric&lang=ru"
    #url = f"http://api.openweathermap.org/data/2.5/weather?q={city_param}&appid={API_KEY}"

    try:
        logger.debug(f"WEATHER REQUEST: {city}")
        async with httpx.AsyncClient(timeout=10) as client:
            r = await client.get(url)
            r.raise_for_status()
            data = r.json()

        if data.get("cod") != 200:
            msg = data.get("message", "unknown error")
            logger.error(f"Weather API error: {msg}")
            return f"Не удалось получить погоду: {msg}"

        weather_info = data["weather"][0]
        main_info = data["main"]
        wind_info = data.get("wind", {})

        desc = weather_info.get("description", "неизвестно")
        temp = main_info.get("temp")
        feels = main_info.get("feels_like")
        humidity = main_info.get("humidity")
        wind = wind_info.get("speed")

        weather_text = (
            f"Погода в {city.capitalize()}:\n"
            f"{desc.capitalize()}, температура {temp}°C, "
            f"ощущается как {feels}°C, влажность {humidity}%, "
            f"ветер {wind} м/с."
        )

        logger.debug(f"WEATHER RESPONSE: {weather_text}")
        return weather_text

    except httpx.HTTPStatusError as http_err:
        logger.error(f"HTTP error: {http_err}")
        return f"Не удалось получить погоду: HTTP {http_err.response.status_code}"
    except Exception as e:
        logger.error(f"Unexpected error: {e}")
        return f"Не удалось получить погоду: {str(e)}"